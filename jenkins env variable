pipeline{
    agent any

    tools{
        maven 'mymaven'
    }
    environment{
        AppName = 'AddressBookApp'
        Build_Env = 'Dev'
    }
    stages{
        stage('checkout code'){
            steps{
                echo "Checking out from Github for ${AppName} in ${Build_Env} environment"
                git 'https://github.com/rakeshr6/DevOpsCodeDemo.git'

            }
        }
        stage('build'){
            steps{
                echo "Building the app ${AppName} using Maven"
                sh 'mvn package'
            }
        }
        stage('test'){
            environment{
                Test_Type = 'Smoke'
                Test_Report_Dir = 'target/surefire-reports'
            }
            steps{
                // stageResult : is the result of the stage
                // buildResult : is the result of the build
                // Though the stage may fail, the build will be successful and the next stage will execute

                catchError(buildResult: 'Success', stageResult: 'FAILURE' ) {

                    sh 'mn compile' // risky code - code that may fail
                    echo "Running ${Test_Type} for tests ${AppName} in ${Build_Env} environment"
                    sh 'mvn test'
                    echo "Publishing test reports and path is ${Test_Report_Dir}"
                    
                }

            }
            script{
                timeout(time: 5, unit: 'MINUTES') {
                input message: 'Do you want to Deploy the Code?', ok: 'Yes, Run the tests'
                }
            }
        }
    }
}